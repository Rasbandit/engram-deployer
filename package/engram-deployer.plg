<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
  <!ENTITY name      "engram-deployer">
  <!ENTITY author    "Rasbandit">
  <!ENTITY version   "0.0.0-DEV">
  <!ENTITY arch      "x86_64">
  <!ENTITY build     "1">
  <!ENTITY pkg       "&name;-&version;-&arch;-&build;">
  <!ENTITY gitURL    "https://github.com/&author;/engram-deployer">
  <!ENTITY pluginURL "https://raw.githubusercontent.com/&author;/engram-deployer/main/package/engram-deployer.plg">
  <!ENTITY plugin    "/boot/config/plugins/&name;">
  <!ENTITY md5       "REPLACE_WITH_PACKAGE_MD5">
]>

<PLUGIN
  name="&name;"
  author="&author;"
  version="&version;"
  pluginURL="&pluginURL;"
  min="6.12">

<CHANGES>
<![CDATA[

### &version;
- pull-based deploy daemon for Engram on FastRaid
- OIDC + JTI + IP allowlist gates on /deploy
- replaces CI-pushes-via-SSH-as-root pattern

]]>
</CHANGES>

<!--
  Canonical Unraid plugin pattern: Slackware .txz installed via
  upgradepkg. Slackware tooling extracts to /, normalizes ownership to
  root:root, runs install/doinst.sh (cert gen + daemon start), and
  registers files for clean removal via removepkg.
-->
<FILE Name="&plugin;/&pkg;.txz" Run="upgradepkg --install-new">
<URL>&gitURL;/releases/download/v&version;/&pkg;.txz</URL>
<MD5>&md5;</MD5>
</FILE>

<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
removepkg &pkg; >/dev/null 2>&1 || true
echo "engram-deployer removed; cert + env preserved in &plugin;/"
]]>
</INLINE>
</FILE>

</PLUGIN>
